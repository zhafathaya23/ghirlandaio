[0.001, "o", "     Loaded: loaded (\u001b]8;;file://salfa/usr/lib/systemd/system/mariadb.service\u001b\\/usr/lib/systemd/system/mariadb.service\u001b]8;;\u001b\\; \u001b[0;1;32menabled\u001b[0m; preset: \u001b[0;1;33m\u001b[0;1;38:5:185mdisabled\u001b[0m)\r\n     Active: \u001b[0;1;32mactive (running)\u001b[0m since Tue 2026-06-02 11:52:40 WIB; 20s ago\r\n"]
[0.002, "o", " Invocation: 46e2e6f9219945b588fa3873e078f21b\r\n       Docs: \u001b]8;;man:mariadbd(8)\u001b\\man:mariadbd(8)\u001b]8;;\u001b\\\r\n             \u001b]8;;https://mariadb.com/kb/en/library/systemd/\u001b\\https://mariadb.com/kb/en/library/systemd/\u001b]8;;\u001b\\\r\n    Process: 1253 ExecStartPre=/bin/sh -c [ ! -e /usr/bin/galera_recovery ] && VAR= ||   VAR=`/usr/bin/galera_recovery`; [ $? -eq 0 ]   && echo _WSREP_START_POSITION=$VAR > /run/mariadb/wsrep-start-position || exit 1 (code=exited, status=0/\r\nSUCCESS)\r\n    Process: 1292 ExecStartPost=/bin/rm -f /run/mariadb/wsrep-start-position /run/mariadb/wsrep-new-cluster (code=exited, status=0/SUCCESS)\r\n   Main PID: 1279 (mariadbd)\r\n     Status: \"\u001b[0;1;36mTaking your SQL requests now...\u001b[0m\"\r\n      Tasks: 13\u001b[0;90m\u001b[0;38:5:245m (limit: 120867)\u001b[0m\r\n     Memory: 96.7M (peak: 98.4M)\r\n        CPU: 640ms\r\n     CGroup: /system.slice/mariadb.service\r\n             └─\u001b[0;90m\u001b[0;38:5:245m1279 /usr/bin/mariadbd\u001b[0m\r\n\r\nJun 02 11:52:39 salfa mariadbd[1279]: 2026-06-02 11:52:39 0 [Note] InnoDB: log sequence number 45141; transaction id 14\r\nJun 02 11:52:39 salfa mariadbd[1279]: 2026-06-02 11:52:39 0 [Note] Plugin 'wsrep-provider' is disabled.\r\nJun 02 11:52:39 salfa mariadbd[1279]: 2026-06-02 11:52:39 0 [Note] InnoDB: Loading buffer pool(s) from /var/lib/mysql/ib_buffer_pool\r\nJun 02 11:52:39 salfa mariadbd[1279]: 2026-06-02 11:52:39 0 [Note] InnoDB: Buffer pool(s) load completed at 260602 11:52:39\r\nJun 02 11:52:40 salfa mariadbd[1279]: 2026-06-02 11:52:40 0 [Note] Server socket created on IP: '0.0.0.0', port: '3306'.\r\nJun 02 11:52:40 salfa mariadbd[1279]: 2026-06-02 11:52:40 0 [Note] Server socket created on IP: '::', port: '3306'.\r\nJun 02 11:52:40 salfa mariadbd[1279]: 2026-06-02 11:52:40 0 [Note] mariadbd: Event Scheduler: Loaded 0 events\r\nJun 02 11:52:40 salfa mariadbd[1279]: 2026-06-02 11:52:40 0 [Note] /usr/bin/mariadbd: ready for connections.\r\nJun 02 11:52:40 salfa mariadbd[1279]: Version: '11.8.6-MariaDB'  socket: '/run/mysqld/mysqld.sock'  port: 3306  Arch Linux\r\nJun 02 11:52:40 salfa systemd[1]: Started MariaDB 11.8.6 database server.\r\n\u001b[?2004h[root@salfa http]# "]
